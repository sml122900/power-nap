{
  "name": "power-nap",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.110.1",
    "expo": "~57.0.4",
    "expo-alarm-module": "^1.2.0",
    "expo-asset": "~57.0.2",
    "expo-audio": "~57.0.0",
    "expo-constants": "~57.0.2",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-intent-launcher": "~57.0.0",
    "expo-keep-awake": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-localization": "~57.0.0",
    "expo-notifications": "~57.0.3",
    "expo-router": "~57.0.4",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "i18next": "^26.3.5",
    "react": "19.2.3",
    "react-i18next": "^17.0.8",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@react-native/jest-preset": "^0.86.0",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "~57.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~57.0.1",
    "test-renderer": "^1.2.0",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest"
  },
  "private": true,
  "jest": {
    "projects": [
      {
        "displayName": "app",
        "preset": "jest-expo",
        "moduleNameMapper": {
          "^@/(.*)$": "<rootDir>/src/$1"
        },
        "testPathIgnorePatterns": [
          "/node_modules/",
          "<rootDir>/supabase/"
        ],
        "setupFilesAfterEnv": [
          "<rootDir>/jest.i18n.setup.js"
        ]
      },
      {
        "displayName": "supabase",
        "testEnvironment": "node",
        "testMatch": [
          "<rootDir>/supabase/**/*.test.ts"
        ],
        "setupFiles": [
          "<rootDir>/jest.env.setup.js"
        ],
        "transform": {
          "^.+\\.tsx?$": [
            "babel-jest",
            {
              "presets": [
                "@babel/preset-typescript"
              ],
              "plugins": [
                "@babel/plugin-transform-modules-commonjs"
              ],
              "babelrc": false,
              "configFile": false
            }
          ]
        }
      }
    ]
  }
}
