# Supabase 대시보드 → Project Settings → API Keys에서 확인 (신형 publishable/secret 체계).
# publishable key는 노출돼도 되는 키(RLS로 보호) — 앱 번들에 들어간다.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# secret key는 절대 EXPO_PUBLIC_ 접두사를 붙이지 않는다 — 앱 코드에서 아예 읽지 않고,
# CLI(supabase db push 등)나 추후 Edge Function secrets 등록에만 쓴다.
SUPABASE_SECRET_KEY=

# supabase login/link용 personal access token — CLI 전용, 앱 코드에서 읽지 않는다.
SUPABASE_ACCESS_TOKEN=

# RevenueCat 대시보드 → Project settings → API keys에서 확인 (Public SDK Key, Android).
# src/config.ts의 REVENUECAT_STORE('test'|'play')가 둘 중 어느 걸 쓸지 고른다 —
# Play Console 계정(DUNS) 발급 전까지는 TEST(RevenueCat Test Store)로 파이프라인
# 전체를 검증하고, 발급 후 PLAY로 전환한다(AI_ANALYSIS.md §7 Phase D 참고).
EXPO_PUBLIC_REVENUECAT_KEY_TEST=
EXPO_PUBLIC_REVENUECAT_KEY_PLAY=
