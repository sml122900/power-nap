{
  "expo": {
    "name": "PowerNap",
    "slug": "power-nap",
    "scheme": "powernap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.lifebook.powernap",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      "expo-status-bar",
      "expo-font",
      [
        "expo-audio",
        {
          "recordAudioAndroid": false,
          "enableBackgroundPlayback": false
        }
      ],
      "expo-notifications",
      "expo-asset",
      "expo-alarm-module",
      "./plugins/withFullScreenAlarmIntent.js",
      "./plugins/withAlarmStopVibrationFix.js",
      "./plugins/withAlarmForegroundStartFix.js",
      "./plugins/withHomeScreenWidgets.js",
      "./plugins/withRemoveUnusedDebugEntries.js",
      "./plugins/withReleaseSigning.js",
      "expo-localization"
    ]
  }
}
